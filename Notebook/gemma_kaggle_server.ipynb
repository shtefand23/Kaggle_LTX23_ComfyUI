   "source": "# ── 4. (opt.) STOP ──────────────────────────────────────────────────────────\nimport subprocess\nsubprocess.run(\"pkill -f llama_cpp.server; pkill -f cloudflared\", shell=True)\nprint(\"Server and tunnel stopped.\")\n"
  }
