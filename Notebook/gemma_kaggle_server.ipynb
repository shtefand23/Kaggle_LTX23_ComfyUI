   "source": "# ── 3. (opt.) TEST ──────────────────────────────────────────────────────────\nimport json, time, urllib.request\n\nURL = f\"http://127.0.0.1:8080/v1/chat/completions\"\nbody = json.dumps({\"model\": \"gemma\",\n    \"messages\": [{\"role\": \"user\", \"content\": \"Hello! Answer in one word.\"}],\n    \"max_tokens\": 32, \"temperature\": 0.7}).encode()\nreq = urllib.request.Request(URL, data=body, headers={\"Content-Type\": \"application/json\"})\nt = time.time()\nr = json.loads(urllib.request.urlopen(req, timeout=120).read())\nprint(\"Response:\", r[\"choices\"][0][\"message\"][\"content\"].strip())\nprint(\"Latency:\", round(time.time() - t, 2), \"s |\", r.get(\"usage\"))\n"
  },
