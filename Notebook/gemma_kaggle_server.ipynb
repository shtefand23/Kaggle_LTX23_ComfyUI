   "source": "# Gemma 4 (Q8_0) — OpenAI Server on Kaggle (2× T4) + Public URL\n\nSets up **llama-cpp-python** with CUDA on two Tesla T4s, an OpenAI-compatible server\nand **Cloudflare tunnel** → public URL for connecting from **Open Code** / any\nOpenAI client.\n\n**Connect from Open Code:**\n- Base URL: `<public_url>/v1`\n- API key: any non-empty (e.g. `sk-local`)\n- Model: `/kaggle/working/models/gemma4-v2-Q8_0.gguf`\n\nTested on hardware (2× T4, driver 580.x, CUDA 12.8, Python 3.12):\nboth cards load via `tensor_split`, response ~0.6 s."
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "# ── 1. INSTALLATION AND DOWNLOAD ────────────────────────────────────────────\nimport os, subprocess, sys\n\nMODEL_DIR  = \"/kaggle/working/models\"\nMODEL_PATH = f\"{MODEL_DIR}/gemma4-v2-Q8_0.gguf\"\nREPO_ID    = \"yuxinlu1/gemma-4-12B-agentic-fable5-composer2.5-v2-3.5x-tau2-GGUF\"\nHOME       = os.path.expanduser(\"~\")\nCF_BIN     = f\"{HOME}/cloudflared\"\nos.makedirs(MODEL_DIR, exist_ok=True)\n\n# llama-cpp-python with CUDA: pre-built wheel from abetlen index (cu124 works on\n# cu128 driver). [server] adds an OpenAI-compatible server.\n# Note: deepbeepmeep llamacpp_gguf_cuda wheel is cp311, won't install on Python 3.12\n# Kaggle image, and isn't needed: this wheel already gives full GPU-offload on both T4s.\ntry:\n    import llama_cpp  # noqa: F401\n    print(\"[*] llama-cpp-python already installed:\", llama_cpp.__version__)\nexcept ImportError:\n    print(\"[*] Installing llama-cpp-python[server] (CUDA wheel)...\")\n    subprocess.run([sys.executable, \"-m\", \"pip\", \"install\", \"-q\", \"--prefer-binary\",\n                    \"llama-cpp-python[server]\",\n                    \"--extra-index-url\",\n                    \"https://abetlen.github.io/llama-cpp-python/whl/cu124\"], check=True)\n\nsubprocess.run([sys.executable, \"-m\", \"pip\", \"install\", \"-q\", \"huggingface_hub\"], check=False)\n\n# cloudflared: download binary directly (more reliable than pip package), +x required.\nif not os.path.exists(CF_BIN) or os.path.getsize(CF_BIN) < 5_000_000:\n    print(\"[*] Downloading cloudflared...\")\n    subprocess.run([\"wget\", \"-q\",\n        \"https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64\",\n        \"-O\", CF_BIN], check=True)\nos.chmod(CF_BIN, 0o755)\nprint(\"[*] cloudflared ready\")\n\n# Model (~12.7 GB) — download only if not already present.\nif not os.path.exists(MODEL_PATH):\n    print(\"[*] Downloading model (~12.7 GB)...\")\n    from huggingface_hub import hf_hub_download\n    hf_hub_download(repo_id=REPO_ID, filename=\"gemma4-v2-Q8_0.gguf\",\n                    local_dir=MODEL_DIR)\nprint(\"[*] MODEL:\", MODEL_PATH,\n      f\"({os.path.getsize(MODEL_PATH)/1e9:.1f} GB)\" if os.path.exists(MODEL_PATH) else \"(missing)\")\n"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "# ── 2. LAUNCH SERVER + TUNNEL ────────────────────────────────────────────────\nimport os, re, time, json, signal, subprocess, urllib.request\n\nPORT       = 8080\nMODEL_PATH = \"/kaggle/working/models/gemma4-v2-Q8_0.gguf\"\nCF_BIN     = os.path.expanduser(\"~/cloudflared\")\nLOG        = \"/kaggle/working/server.log\"\n\n# Idempotency: kill previous processes before re-launch.\nsubprocess.run(\"pkill -f gemma_server.py; pkill -f llama_cpp.server; pkill -f cloudflared\", shell=True)\ntime.sleep(2)\n\n# Launcher wrapper: llama_cpp.server can't set swa_full via CLI, and for Gemma at\n# 256k it's required — otherwise SWA layers allocate KV for full context (~90 GB, OOM).\n# swa_full=False → efficient KV cache (sliding window 1024), flash_attn removes\n# V-cache padding and huge attention buffer. Result: ~20 GB out of 30 at 256k.\nLAUNCHER = \"/kaggle/working/gemma_server.py\"\nwith open(LAUNCHER, \"w\") as f:\n    f.write(\n        \"import sys, runpy, llama_cpp\\n\"\n        \"_orig = llama_cpp.Llama.__init__\\n\"\n        \"def _init(self, *a, **k):\\n\"\n        \"    k.setdefault('swa_full', False)\\n\"\n        \"    return _orig(self, *a, **k)\\n\"\n        \"llama_cpp.Llama.__init__ = _init\\n\"\n        \"runpy.run_module('llama_cpp.server', run_name='__main__')\\n\"\n    )\n\n# Server: both T4s via tensor_split, all layers on GPU, full 256k window.\nserver = subprocess.Popen([\n    \"python\", LAUNCHER,\n    \"--model\", MODEL_PATH,\n    \"--host\", \"0.0.0.0\", \"--port\", str(PORT),\n    \"--n_gpu_layers\", \"999\",\n    \"--tensor_split\", \"0.5\", \"0.5\",\n    \"--n_ctx\", \"262144\",       # full 256k window\n    \"--n_batch\", \"256\",\n    \"--n_ubatch\", \"128\",       # CRITICAL: small prompt-eval chunk → no OOM on large prompts (opencode sends 30k+ tokens)\n    \"--flash_attn\", \"true\",    # required for 256k: small attention buffer + V-cache without padding\n    \"--use_mlock\", \"false\",    # CRITICAL: default True locks 12.7 GB in RAM → OOM. Off = weights stream into VRAM\n    \"--use_mmap\", \"true\",      # mmap: file pages → GPU, almost no RAM used\n], stdout=open(LOG, \"w\"), stderr=subprocess.STDOUT)\nprint(\"[*] server PID:\", server.pid, \"(log:\", LOG + \")\")\n\n# Cloudflare tunnel.\ntun = subprocess.Popen(\n    [CF_BIN, \"tunnel\", \"--no-autoupdate\", \"--protocol\", \"http2\",\n     \"--url\", f\"http://127.0.0.1:{PORT}\"],\n    stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True, bufsize=1)\n\npublic = None\nt0 = time.time()\nwhile time.time() - t0 < 90:\n    line = tun.stdout.readline()\n    if not line:\n        if tun.poll() is not None:\n            break\n        continue\n    m = re.search(r\"https://[^\s]+trycloudflare\\.com\", line)\n    if m:\n        public = m.group(0)\n        break\n\n# Wait for model to load (~20–60 s for Q8 on 2× T4).\ndef ready():\n    try:\n        urllib.request.urlopen(f\"http://127.0.0.1:{PORT}/v1/models\", timeout=3).read()\n        return True\n    except Exception:\n        return False\n\nprint(\"[*] Waiting for model to load...\")\nt0 = time.time()\nwhile time.time() - t0 < 240 and not ready():\n    if server.poll() is not None:\n        raise RuntimeError(\"Server crashed — check \" + LOG)\n    time.sleep(5)\n\nprint(\"\\n\" + \"=\" * 64)\nif public and ready():\n    print(\"✅ DONE. Public URL:\", public)\n    print(\"\\nOpen Code / OpenAI client:\")\n    print(\"  Base URL :\", public + \"/v1\")\n    print(\"  API key  : sk-local  (any non-empty)\")\n    print(\"  Model    :\", MODEL_PATH)\nelse:\n    print(\"⚠️  URL:\", public, \"| server ready:\", ready(), \"— check\", LOG)\nprint(\"=\" * 64)\n"
  },
