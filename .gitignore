.ipynb_checkpoints/
/*.ipynb

# --- Локальные тесты и драйверы Kaggle (токены, временные скрипты) ---
_kaggle_tests/

# --- Сторонние/смежные проекты, заметки и IDE-папки (живут отдельно) ---
angel-ui/
Claude Code Docs/
.vscode/
.idea/
.DS_Store
Thumbs.db

